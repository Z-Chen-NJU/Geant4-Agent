{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MaterialSpec",
  "type": "object",
  "properties": {
    "material": {
      "type": "string",
      "description": "Geant4 material name (e.g., G4_Si, G4_WATER)"
    },
    "temperature_K": {
      "type": "number",
      "minimum": 0.0,
      "description": "Temperature in Kelvin"
    },
    "pressure_Pa": {
      "type": "number",
      "minimum": 0.0,
      "description": "Pressure in Pascal"
    },
    "density_g_cm3": {
      "type": "number",
      "minimum": 0.0,
      "description": "Density in g/cm^3 (optional override)"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": ["material"],
  "additionalProperties": false
}
